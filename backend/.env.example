# Akces Booth Backend - Example config.
# Skopiuj do `.env` i uzupelnij wartosci.

SECRET_KEY=change-me-to-random-string
STORAGE_PATH=./storage
DB_PATH=./db/akces_booth.db

# 500 MB max upload (duze sa tylko 4K / 8K)
MAX_UPLOAD_SIZE=524288000

PORT=5100
HOST=0.0.0.0

# Publiczny URL (za Cloudflare tunnel). W dev: http://localhost:5100
PUBLIC_BASE_URL=http://localhost:5100

# Gemini API - zreuzyj z Akces Hub. Wymagane dla AI ramki.
GEMINI_API_KEY=

# Admin panel login
ADMIN_USERNAME=adrian
ADMIN_PASSWORD=change-me-strong-password

# Station -> Backend upload auth. Losowy string, sync'owany z Station Settings.
STATION_API_KEY=random-key-for-station

# Logi
LOG_LEVEL=INFO
